			"settings": {
				"foreground": "#c5e478"
			}
		},
		{
			"name": "Number",
			"scope": ["constant.numeric", "constant.character.numeric"],
			"settings": {
				"foreground": "#F78C6C",
				"fontStyle": ""
			}
		},
		{
			"name": "Built-in constant",
			"scope": [
				"constant.language",
				"punctuation.definition.constant",
				"variable.other.constant"
			],
			"settings": {
				"foreground": "#82AAFF"
			}
		},
		{
			"name": "User-defined constant",
